# === LLM 配置（MiniMax M3） ===
# API key 从 https://platform.minimaxi.com 获取
MINIMAX_API_KEY=sk-xxx-replace-with-your-real-key
MINIMAX_BASE_URL=https://platform.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3

# === 数据库 ===
# 本地开发用 SQLite；生产可改为 postgresql+asyncpg://user:pass@host:5432/db
DATABASE_URL=sqlite+aiosqlite:///./data/policy_radar.db

# === 微信 iLink Mock 服务 ===
MOCK_WECHAT_URL=http://localhost:9999
MOCK_WECHAT_PORT=9999

# === FastAPI 服务 ===
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# === 爬虫 ===
CRAWLER_REQUEST_INTERVAL_MIN=3
CRAWLER_REQUEST_INTERVAL_MAX=5
CRAWLER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# === LLM 调用 ===
LLM_TEXT_MAX_CHARS=6000
LLM_SUMMARIZE_CONCURRENCY=2
